# RUCKUS One API credentials
RUCKUS_TENANT_ID=your-tenant-id
RUCKUS_CLIENT_ID=your-client-id
RUCKUS_CLIENT_SECRET=your-client-secret
# e.g. us, eu, asia; leave blank if not needed
RUCKUS_REGION=your-region

# Optional: Serial number of a physical AP for testing add/remove operations
# This AP will be temporarily added to a venue/AP group and then removed during testing
TEST_AP_SERIAL_NUMBER=1234567890

# Optional: SAML IdP metadata URL for the SAML IdP profile tests (TC-INT-340 / TC-INT-341).
# RUCKUS One fetches this server-side, so the IdP must be reachable from R1's backend.
SAML_IDP_METADATA_URL=https://your-idp-host/realms/your-realm/protocol/saml/descriptor
# The IdP hostname (the host of SAML_IDP_METADATA_URL). Used as the SAML WLAN's walled-garden
# entry so captive-portal clients can reach the IdP to sign in pre-authentication (TC-INT-341).
SAML_IDP_HOST=your-idp-host
